# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cooltour"

# JWT — genera uno con: openssl rand -hex 32
JWT_SECRET="cambia_esto_por_algo_seguro"

# Puerto
PORT=3000

# Storage para audios (Cloudflare R2 o AWS S3)
S3_BUCKET="cool-tour-audio"
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY="tu_access_key"
S3_SECRET_KEY="tu_secret_key"
